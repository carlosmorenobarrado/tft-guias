---
import Layout from '../../layouts/Layout.astro';
import TierBadge from '../../components/TierBadge.astro';
import StatBar from '../../components/StatBar.astro';
import CompCard from '../../components/CompCard.astro';
import BoardDisplay from '../../components/BoardDisplay.astro';

const guideModules = import.meta.glob('../../data/guides/*.json', { eager: true });
const allGuides = Object.values(guideModules) as any[];

export function getStaticPaths() {
  const guideModules = import.meta.glob('../../data/guides/*.json', { eager: true });
  const guides = Object.values(guideModules) as any[];
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const tier = guide.top4Rate >= 0.90 ? 'S' : guide.top4Rate >= 0.75 ? 'A' : 'B';

const severidadStyles = {
  critica: 'bg-red-500/20 border-red-500 text-red-400',
  alta: 'bg-orange-500/20 border-orange-500 text-orange-400',
  media: 'bg-yellow-500/20 border-yellow-500 text-yellow-400',
};

const prioridadStyles = {
  alta: 'border-red-500/50',
  media: 'border-yellow-500/50',
  baja: 'border-green-500/50',
};

// Find related comps: same difficulty or similar traits
const currentTraits = guide.traits.map((t: any) => t.nombre.toLowerCase());
const relatedComps = allGuides
  .filter(g => g.slug !== guide.slug)
  .map(g => {
    const gTraits = g.traits.map((t: any) => t.nombre.toLowerCase());
    const sharedTraits = currentTraits.filter((t: string) => gTraits.includes(t)).length;
    const sameDifficulty = g.dificultad === guide.dificultad;
    return { ...g, score: sharedTraits + (sameDifficulty ? 1 : 0) };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<Layout
  title={`${guide.nombre} - Guia TFT Set 16 | TFT Stats ES`}
  description={`Guia completa de ${guide.nombre} en TFT Set 16. ${(guide.top4Rate * 100).toFixed(1)}% top 4 rate en ${guide.nGames} partidas Challenger. Items, gameplan y variantes.`}
>
  <!-- Breadcrumb -->
  <nav class="mb-6 text-sm">
    <ol class="flex items-center gap-2 text-tft-gold/60">
      <li>
        <a href="/" class="hover:text-tft-orange transition-colors">Inicio</a>
      </li>
      <li class="text-tft-orange/40">&gt;</li>
      <li>
        <a href="/" class="hover:text-tft-orange transition-colors">Tier List</a>
      </li>
      <li class="text-tft-orange/40">&gt;</li>
      <li class="text-tft-gold">{guide.nombreCorto || guide.nombre}</li>
    </ol>
  </nav>

  <!-- Header -->
  <header class="mb-8">
    <div class="flex items-start gap-4 mb-4">
      <TierBadge tier={tier} />
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-tft-gold">{guide.nombre}</h1>
        <p class="text-tft-gold/60">
          {guide.nGames} partidas analizadas | Dificultad:
          <span class={guide.dificultad === 'Alta' ? 'text-red-400' : guide.dificultad === 'Media' ? 'text-yellow-400' : 'text-green-400'}>
            {guide.dificultad}
          </span>
        </p>
      </div>
    </div>

    <p class="text-tft-gold/80 mb-6">{guide.descripcion}</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-tft-orange/10 rounded-lg p-4">
        <div class="text-2xl font-bold text-tier-s">{(guide.top4Rate * 100).toFixed(1)}%</div>
        <div class="text-sm text-tft-gold/60">Top 4 Rate</div>
      </div>
      <div class="bg-tft-orange/10 rounded-lg p-4">
        <div class="text-2xl font-bold text-tft-blue">{(guide.winRate * 100).toFixed(1)}%</div>
        <div class="text-sm text-tft-gold/60">Win Rate</div>
      </div>
      <div class="bg-tft-orange/10 rounded-lg p-4">
        <div class="text-2xl font-bold text-tft-orange">{guide.avgPlacement.toFixed(2)}</div>
        <div class="text-sm text-tft-gold/60">Avg Placement</div>
      </div>
      <div class="bg-tft-orange/10 rounded-lg p-4">
        <div class="text-2xl font-bold text-tft-purple">{guide.avgLevel}</div>
        <div class="text-sm text-tft-gold/60">Avg Level</div>
      </div>
    </div>
  </header>

  <!-- AdSense Placeholder -->
  <div class="mb-8 p-4 border border-dashed border-tft-orange/20 rounded-lg text-center text-tft-gold/40 text-sm">
    <!-- Google AdSense ad unit -->
  </div>

  <!-- Traits -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-tft-orange mb-4">Traits Activos</h2>
    <div class="flex flex-wrap gap-2">
      {guide.traits.map((trait: { nombre: string; count: number }) => (
        <span class="bg-tft-orange/20 border border-tft-orange/40 rounded-full px-3 py-1 text-sm">
          {trait.nombre} {trait.count > 1 && <span class="text-tft-orange">({trait.count})</span>}
        </span>
      ))}
    </div>
  </section>

  <!-- Board Completo -->
  {guide.board_completo && (
    <section class="mb-8">
      <h2 class="text-xl font-bold text-tft-orange mb-4">Board Completo</h2>
      <p class="text-tft-gold/60 mb-4">Las 9 unidades más frecuentes en top-4 con este core.</p>
      <BoardDisplay board={guide.board_completo} />
    </section>
  )}

  <!-- Gameplan -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-tft-orange mb-4">Como Jugarla</h2>
    <div class="space-y-4">
      {Object.values(guide.gameplan).map((phase: any) => (
        <div class="bg-tft-dark border border-tft-orange/30 rounded-lg p-4">
          <h3 class="font-bold text-tft-gold mb-2">{phase.titulo}</h3>
          <p class="text-tft-gold/80 mb-3">{phase.descripcion}</p>
          <ul class="space-y-1">
            {phase.tips.map((tip: string) => (
              <li class="text-sm text-tft-gold/70 flex items-start gap-2">
                <span class="text-tft-orange mt-1">•</span>
                {tip}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Items -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-tft-orange mb-4">Items Recomendados</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {Object.entries(guide.items).map(([carry, itemData]: [string, any]) => (
        <div class="bg-tft-dark border border-tft-orange/30 rounded-lg p-4">
          <h3 class="font-bold text-tft-gold mb-3">{carry}</h3>
          <div class="mb-3">
            <div class="text-xs text-tft-gold/50 uppercase mb-1">Core</div>
            <div class="flex flex-wrap gap-1">
              {itemData.core.map((item: string) => (
                <span class="bg-tft-orange/30 rounded px-2 py-0.5 text-sm">{item}</span>
              ))}
            </div>
          </div>
          <div>
            <div class="text-xs text-tft-gold/50 uppercase mb-1">Alternativas</div>
            <div class="flex flex-wrap gap-1">
              {itemData.alternativas.map((item: string) => (
                <span class="bg-tft-gold/10 rounded px-2 py-0.5 text-sm text-tft-gold/70">{item}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Como Ejecutarla Bien (Enriched Stats) -->
  {guide.stats_enriquecidas && (
    <section class="mb-8">
      <h2 class="text-xl font-bold text-tft-orange mb-4">Como Ejecutarla Bien</h2>

      <!-- Badges -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${
          guide.estilo === 'late_game' ? 'bg-blue-500/20 text-blue-400 border border-blue-500/40' :
          guide.estilo === 'mid_game' ? 'bg-green-500/20 text-green-400 border border-green-500/40' :
          'bg-orange-500/20 text-orange-400 border border-orange-500/40'
        }`}>
          {guide.estilo === 'late_game' ? 'Late Game' : guide.estilo === 'mid_game' ? 'Mid Game' : 'Reroll'}
        </span>
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${
          guide.economia === 'rolldown' ? 'bg-red-500/20 text-red-400 border border-red-500/40' :
          guide.economia === 'eco' ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/40' :
          'bg-yellow-500/20 text-yellow-400 border border-yellow-500/40'
        }`}>
          {guide.economia === 'rolldown' ? 'Rolldown Agresivo' : guide.economia === 'eco' ? 'Jugar Interes' : 'Economia Mixta'}
        </span>
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${
          guide.presion === 'alta' ? 'bg-red-500/20 text-red-400 border border-red-500/40' :
          guide.presion === 'baja' ? 'bg-green-500/20 text-green-400 border border-green-500/40' :
          'bg-yellow-500/20 text-yellow-400 border border-yellow-500/40'
        }`}>
          Presion {guide.presion.charAt(0).toUpperCase() + guide.presion.slice(1)}
        </span>
      </div>

      <!-- Metric Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div class="bg-tft-dark border border-tft-orange/30 rounded-lg p-4">
          <div class="text-2xl font-bold text-tft-blue">{guide.stats_enriquecidas.avg_last_round_top4}</div>
          <div class="text-sm text-tft-gold/60 mb-1">Ronda de Supervivencia</div>
          <div class="text-xs text-tft-gold/50">Los que ganan aguantan hasta ronda {guide.stats_enriquecidas.avg_last_round_top4} de media</div>
        </div>
        <div class="bg-tft-dark border border-tft-orange/30 rounded-lg p-4">
          <div class="text-2xl font-bold text-tft-purple">{(guide.stats_enriquecidas.pct_nivel_9_top4 * 100).toFixed(0)}%</div>
          <div class="text-sm text-tft-gold/60 mb-1">Nivel Critico</div>
          <div class="text-xs text-tft-gold/50">De los top-4, el {(guide.stats_enriquecidas.pct_nivel_9_top4 * 100).toFixed(0)}% llega a nivel 9</div>
        </div>
        <div class="bg-tft-dark border border-tft-orange/30 rounded-lg p-4">
          <div class="text-2xl font-bold text-tft-orange">{guide.stats_enriquecidas.avg_gold_left_top4}</div>
          <div class="text-sm text-tft-gold/60 mb-1">Oro Sobrante</div>
          <div class="text-xs text-tft-gold/50">{guide.stats_enriquecidas.avg_gold_left_top4} oro de media — rolldown {guide.stats_enriquecidas.avg_gold_left_top4 <= 4 ? 'agresivo' : guide.stats_enriquecidas.avg_gold_left_top4 <= 8 ? 'moderado' : 'conservador'}</div>
        </div>
      </div>

      <!-- Insight Box -->
      {guide.insight_ejecucion && (
        <div class="bg-tft-orange/10 border-l-4 border-tft-orange rounded-r-lg p-4">
          <div class="text-sm font-medium text-tft-orange mb-1">Insight de Ejecucion</div>
          <p class="text-tft-gold/90">{guide.insight_ejecucion}</p>
        </div>
      )}
    </section>
  )}

  <!-- Variantes (Diferenciador) -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-tft-orange mb-4">Variantes</h2>
    <p class="text-tft-gold/60 mb-4">Ajusta tu juego segun lo que encuentres en la partida.</p>
    <div class="space-y-3">
      {guide.variantes.map((variante: any) => (
        <div class={`bg-tft-dark border-l-4 ${prioridadStyles[variante.prioridad as keyof typeof prioridadStyles]} border border-tft-orange/30 rounded-lg p-4`}>
          <div class="font-medium text-tft-gold mb-1">
            Si: <span class="text-tft-orange">{variante.condicion}</span>
          </div>
          <div class="text-tft-gold/80">{variante.ajuste}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pivot Alerts (Diferenciador) -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-tft-orange mb-4">Cuando Pivotar</h2>
    <p class="text-tft-gold/60 mb-4">Senales de que debes abandonar esta comp.</p>
    <div class="space-y-3">
      {guide.pivotAlerts.map((alert: any) => (
        <div class={`border rounded-lg p-4 ${severidadStyles[alert.severidad as keyof typeof severidadStyles]}`}>
          <div class="font-medium mb-1">{alert.senal}</div>
          <div class="text-sm opacity-80">
            <span class="font-medium">Alternativa:</span> {alert.alternativa}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Related Comps -->
  {relatedComps.length > 0 && (
    <section class="mb-8 pt-8 border-t border-tft-orange/20">
      <h2 class="text-xl font-bold text-tft-orange mb-4">Otras comps que te pueden interesar</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {relatedComps.map((comp) => (
          <CompCard
            slug={comp.slug}
            nombre={comp.nombre}
            top4Rate={comp.top4Rate}
            winRate={comp.winRate}
            dificultad={comp.dificultad}
            nGames={comp.nGames}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Back link -->
  <div class="mt-8">
    <a href="/" class="text-tft-orange hover:text-tft-gold transition-colors">
      &larr; Volver a la Tier List
    </a>
  </div>
</Layout>
