---
import Layout from '../layouts/Layout.astro';
import CompListCard from '../components/CompListCard.astro';

const guideModules = import.meta.glob('../data/guides/*.json', { eager: true });
const guides = Object.values(guideModules) as any[];

// Tier S+ — comps marcadas explícitamente como S+
const tierSPlus = guides
  .filter(g => g.tier === 'S+')
  .sort((a, b) => b.top4Rate - a.top4Rate);

// Tier S — >= 90% top4 rate, excluyendo las que ya están en S+
const tierS = guides
  .filter(g => g.top4Rate >= 0.90 && g.tier !== 'S+')
  .sort((a, b) => b.top4Rate - a.top4Rate);
---

<Layout
  title="TFT Stats ES - Mejores Comps Set 16 | Meta Challenger EUW"
  description="Las mejores comps de TFT Set 16 en español. Tier list S con datos reales de partidas Challenger y Grandmaster de EUW. Guías completas con items, gameplan y variantes."
>
  <div class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-tft-orange mb-2">
      Mejores Comps TFT Set 16
    </h1>
    <p class="text-tft-gold/70 text-lg">
      Solo Tier S — Comps con +90% top 4 en Challenger/GM EUW
    </p>
  </div>

  <!-- Ocultar placeholder hasta aprobacion AdSense -->
  <!-- <div class="mb-8 p-4 border border-dashed border-tft-orange/20 rounded-lg text-center text-tft-gold/40 text-sm">
    Google AdSense ad unit
  </div> -->

  {/* Tier S+ */}
  {tierSPlus.length > 0 && (
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-500 text-yellow-900 font-bold text-xl">S+</span>
        <div>
          <h2 class="text-xl font-bold text-tft-gold">Tier S+ — Meta Actual</h2>
          <p class="text-sm text-tft-gold/60">La comp más dominante del parche. Validada en liga Maestro.</p>
        </div>
      </div>

      <div class="space-y-3">
        {tierSPlus.map((comp) => (
          <CompListCard
            slug={comp.slug}
            nombre={comp.nombre}
            nombreCorto={comp.nombreCorto}
            top4Rate={comp.top4Rate}
            winRate={comp.winRate}
            dificultad={comp.dificultad}
            nGames={comp.nGames}
            units={comp.board_completo?.units || []}
          />
        ))}
      </div>
    </section>
  )}

  {/* Tier S */}
  {tierS.length > 0 ? (
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-tier-s text-white font-bold text-xl">S</span>
        <div>
          <h2 class="text-xl font-bold text-tft-gold">Tier S — Las Mejores</h2>
          <p class="text-sm text-tft-gold/60">{tierS.length} comps con +90% top 4 rate</p>
        </div>
      </div>

      <div class="space-y-3">
        {tierS.map((comp) => (
          <CompListCard
            slug={comp.slug}
            nombre={comp.nombre}
            nombreCorto={comp.nombreCorto}
            top4Rate={comp.top4Rate}
            winRate={comp.winRate}
            dificultad={comp.dificultad}
            nGames={comp.nGames}
            units={comp.board_completo?.units || []}
          />
        ))}
      </div>
    </section>
  ) : (
    <div class="text-center py-12 text-tft-gold/60">
      <p>No hay comps Tier S disponibles actualmente.</p>
    </div>
  )}

  <!-- Info Section -->
  <section class="mt-12 p-6 bg-tft-orange/5 border border-tft-orange/20 rounded-lg">
    <h2 class="text-xl font-bold text-tft-orange mb-3">Como usar esta guía</h2>
    <div class="grid md:grid-cols-2 gap-4 text-sm text-tft-gold/70">
      <div>
        <h3 class="font-semibold text-tft-gold mb-1">Unidades Core vs Flex</h3>
        <p>Las unidades con borde naranja son el core de la comp. Las demás son flex y pueden cambiar según lo que encuentres.</p>
      </div>
      <div>
        <h3 class="font-semibold text-tft-gold mb-1">Top 4 Rate vs Win Rate</h3>
        <p>Top 4 indica consistencia. Win Rate indica potencial de ganar lobbies. Prioriza Top 4 para subir de rango.</p>
      </div>
    </div>
  </section>

  <!-- Data Source -->
  <section class="mt-6 p-4 bg-tft-dark border border-tft-orange/10 rounded-lg">
    <p class="text-tft-gold/50 text-xs">
      Datos de los top 200 jugadores Challenger/Grandmaster en EUW. Actualizado para el meta actual del Set 16.
    </p>
  </section>
</Layout>
