---
interface Props {
  tier: 'S+' | 'S' | 'A' | 'B';
}

const { tier } = Astro.props;

const tierStyles: Record<string, string> = {
  'S+': 'bg-yellow-500 text-yellow-900',
  S: 'bg-tier-s text-white',
  A: 'bg-tier-a text-white',
  B: 'bg-tier-b text-white',
};
---

<span class={`inline-flex items-center justify-center w-8 h-8 rounded font-bold text-lg ${tierStyles[tier]}`}>
  {tier}
</span>
