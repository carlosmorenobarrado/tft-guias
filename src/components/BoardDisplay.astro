---
interface Unit {
  character_id: string;
  frecuencia: number;
  es_core: boolean;
  tier_habitual: number;
  items: string[];
}

interface Carry {
  unidad: string;
  character_id: string;
  items_ideales: string[];
  items_alternativos?: string[];
}

interface Props {
  board: {
    n_games_analyzed: number;
    units: Unit[];
  };
  carries?: Carry[];
}

const { board, carries } = Astro.props;

// Helper to get items for a unit - prioritizes carries.items_ideales if available
function getUnitItems(unit: Unit): string[] {
  if (carries) {
    const carry = carries.find(c => c.character_id === unit.character_id);
    if (carry && carry.items_ideales && carry.items_ideales.length > 0) {
      return carry.items_ideales;
    }
  }
  return unit.items;
}

// Helper to format unit name
function formatUnitName(charId: string): string {
  return charId.replace("TFT16_", "");
}

// Helper to get champion image URL from Community Dragon
function getChampionImageUrl(charId: string): string {
  const champName = charId.toLowerCase();
  return `https://raw.communitydragon.org/latest/plugins/rcp-be-lol-game-data/global/default/assets/characters/${champName}/hud/${champName}_square.tft_set16.png`;
}

